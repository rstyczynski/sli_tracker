{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["routes"],
  "properties": {
    "adapters": {
      "type": "object",
      "description": "Destination target map. Keys are 'type:name' or 'type'; values are adapter-specific target objects.",
      "additionalProperties": {}
    },
    "mapping": {
      "$ref": "#/$defs/destination",
      "description": "Logical source from which mapping files are fetched. Resolved via the adapters section."
    },
    "source": {
      "$ref": "#/$defs/destination",
      "description": "Logical source from which envelopes are read. Resolved via the adapters section by the host program."
    },
    "dead_letter": {
      "$ref": "#/$defs/destination"
    },
    "routes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/route"
      }
    }
  },
  "$defs": {
    "destination": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "schema_match": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "equals"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "equals": {}
      }
    },
    "match": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "headers": {
          "type": "object",
          "additionalProperties": true
        },
        "endpoint": {
          "type": "string",
          "minLength": 1
        },
        "schema": {
          "$ref": "#/$defs/schema_match"
        },
        "required_fields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "transform": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mapping"],
      "properties": {
        "mapping": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "transform", "destination"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": ["exclusive", "fanout"]
        },
        "priority": {
          "type": "number"
        },
        "match": {
          "$ref": "#/$defs/match"
        },
        "transform": {
          "$ref": "#/$defs/transform"
        },
        "destination": {
          "$ref": "#/$defs/destination"
        }
      }
    }
  }
}

