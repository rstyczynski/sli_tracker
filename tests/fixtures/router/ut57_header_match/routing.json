{
  "routes": [
    {
      "id": "github_workflow_run_to_log",
      "priority": 100,
      "match": {
        "headers": {
          "X-GitHub-Event": "workflow_run"
        }
      },
      "transform": {
        "mapping": "./mapping.jsonata"
      },
      "destination": {
        "type": "oci_log",
        "name": "github_events"
      }
    }
  ]
}
