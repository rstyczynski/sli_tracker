{
  "dead_letter": {
    "type": "dead_letter",
    "name": "errors"
  },
  "routes": [
    {
      "id": "workflow_log",
      "mode": "fanout",
      "match": {
        "headers": {
          "X-GitHub-Event": "workflow_run"
        }
      },
      "transform": {
        "mapping": "./mapping_log.jsonata"
      },
      "destination": {
        "type": "oci_log",
        "name": "github_events"
      }
    },
    {
      "id": "health_endpoint",
      "mode": "exclusive",
      "priority": 50,
      "match": {
        "endpoint": "/health"
      },
      "transform": {
        "mapping": "./mapping_health.jsonata"
      },
      "destination": {
        "type": "oci_metric",
        "name": "health_signal"
      }
    }
  ]
}
