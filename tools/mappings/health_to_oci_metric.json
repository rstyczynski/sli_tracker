{
  "version": "1",
  "description": "Map a /health API response to an OCI Monitoring PostMetricData body",
  "expression": "{ \"metricData\": [{ \"namespace\": \"sli_tracker\", \"name\": \"health_status\", \"compartmentId\": \"${OCI_COMPARTMENT_ID}\", \"datapoints\": [{ \"timestamp\": $now(), \"value\": status = \"UP\" ? 1 : 0 }], \"dimensions\": { \"component\": \"app\", \"status\": status } }] }"
}
