{
  "metricData": [{
    "namespace":     "sli_tracker",
    "name":          "health_status",
    "compartmentId": $env.OCI_COMPARTMENT_ID,
    "datapoints": [{
      "timestamp": $now(),
      "value":     status = "UP" ? 1 : 0
    }],
    "dimensions": {
      "component": "app",
      "status":    status
    }
  }]
}
